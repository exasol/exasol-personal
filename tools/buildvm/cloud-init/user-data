#cloud-config
users:
  - name: alpine
    groups: wheel
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/sh
    plain_text_passwd: alpine
    lock_passwd: false
    ssh_authorized_keys:
      - SSH_PUBLIC_KEY_PLACEHOLDER

packages:
  - openssh

runcmd:
  - rc-update add sshd default
  - service sshd start
  - touch /tmp/cloud-init-complete
