#cloud-config

# Enable community repo for cloud-utils-growpart
bootcmd:
  - echo "https://dl-cdn.alpinelinux.org/alpine/v3.23/community" >> /etc/apk/repositories

# Auto-mount virtiofs shared folder (works with vfkit on Mac)
mounts:
  - [ hostshare, /mnt/host, virtiofs, "defaults,nofail", "0", "0" ]

users:
  - name: alpine
    groups: wheel
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/sh
    plain_text_passwd: alpine
    lock_passwd: false
    ssh_authorized_keys:
      - SSH_PUBLIC_KEY_PLACEHOLDER

packages:
  - openssh
  - cloud-utils-growpart  # for growpart command
  - e2fsprogs             # for resize2fs command
  - podman                # container runtime

runcmd:
  # Grow root partition to use full 3GB disk
  - growpart /dev/vda 2
  - resize2fs /dev/vda2
  # Mount shared folder (if available)
  - mkdir -p /mnt/host
  - mount -a || true
  # Start SSH service
  - rc-update add sshd default
  - service sshd start
  # Signal completion via shared folder
  - touch /mnt/host/cloud-init-complete
  # Clean up to minimize disk usage
  - apk cache clean
  - rm -rf /var/cache/apk/*
  - rm -rf /tmp/* /var/tmp/* || true
  - find /var/log -type f -exec truncate -s 0 {} \;
  # Zero free space for better compression
  - dd if=/dev/zero of=/zerofill bs=1M || true
  - sync
  - rm -f /zerofill
  - sync
  # Shutdown so we can shrink the image
  - poweroff
