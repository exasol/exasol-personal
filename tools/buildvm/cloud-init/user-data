#cloud-config

# Enable community repo for cloud-utils-growpart
bootcmd:
  - echo "https://dl-cdn.alpinelinux.org/alpine/v3.23/community" >> /etc/apk/repositories

# Auto-mount virtiofs shared folder (works with vfkit on Mac)
mounts:
  - [ hostshare, /mnt/host, virtiofs, "defaults,nofail", "0", "0" ]
  - [ none, /sys/fs/cgroup, cgroup2, "defaults", "0", "0" ]

users:
  - name: exasol
    groups: wheel
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/sh
    plain_text_passwd: exasol
    lock_passwd: false
    ssh_authorized_keys:
      - SSH_PUBLIC_KEY_PLACEHOLDER

packages:
  - openssh
  - cloud-utils-growpart  # for growpart command
  - e2fsprogs             # for resize2fs command
  - xz                    # needed by linux.run self-extractor
  - bash                  # needed by extracted DB scripts

runcmd:
  # Copy scripts from shared folder to system
  - cp /mnt/host/scripts/*.sh /usr/local/bin/
  - chmod +x /usr/local/bin/*.sh
  # Run setup scripts
  - /usr/local/bin/setup-system.sh
  - /usr/local/bin/setup-services.sh
  # Load and start the database from shared folder
  - /usr/local/bin/load-db.sh
  # Cleanup and shutdown
  - /usr/local/bin/cleanup-and-shutdown.sh
